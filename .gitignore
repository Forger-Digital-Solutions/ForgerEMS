# ForgerEMS source repository ignore policy
# Track source, scripts, manifests, docs, and installer configuration only.

# .NET / Visual Studio
**/bin/
**/obj/
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
TestResults/
coverage/

# Build and release outputs
dist/
release/
PreRelease/
*.zip
*.exe
*.msi
*.nupkg
*.snupkg
*.log

# Large USB / OS / portable payloads
*.iso
*.img
*.vhd
*.vhdx
*.wim
*.esd
ISO/
MediCat.USB/
Drivers/
ForgerTools/
Tools/Portable/
tools/Portable/
Portable/
portable-tools/
portable/

# Local verification and download scratch space
.verify/*
!.verify/
!.verify/README.md
.tmp/
_archive/
_downloads/
_logs/
_reports/

# Local-only operator notes and shortcuts
docs/ForgerEMS-Bootstrap-Notes.txt
docs/ForgerEMS-Link-Inventory.csv
backend/legacy/VentoyToolkitSetup/*.url
backend/legacy/VentoyToolkitSetup/IfScriptFails(ManualSetup)/
/DOWNLOAD - MediCat.url
/ForgerEMS.updates.json

# Temporary files
*.tmp
*.temp
*.bak
*.orig
