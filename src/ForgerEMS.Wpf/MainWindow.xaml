<Window x:Class="VentoyToolkitSetup.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ForgerEMS"
        Icon="Assets/ForgerEMS.ico"
        Width="1366"
        Height="820"
        MinWidth="1100"
        MinHeight="700"
        WindowState="Normal"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Manual"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="CircuitBaseTraceStyle" TargetType="Path">
            <Setter Property="StrokeThickness" Value="3" />
            <Setter Property="Opacity" Value="0.52" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style x:Key="CircuitPulseTraceStyle" TargetType="Path">
            <Setter Property="StrokeThickness" Value="2.8" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="StrokeDashArray" Value="2 22" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style x:Key="CircuitNodeLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,7,0,0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F8FBFF" />
            <Setter Property="Opacity" Value="0.98" />
        </Style>

        <Style x:Key="SatelliteNodeStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="74" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#5522323F" />
            <Setter Property="BorderBrush" Value="#99AFC4D9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Opacity" Value="0.78" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style x:Key="SatelliteNodeLabelStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F2F7FF" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="PackageGroupLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#D5E8FA" />
            <Setter Property="Opacity" Value="0.78" />
        </Style>

        <Style x:Key="ToolTraceStyle" TargetType="Path">
            <Setter Property="StrokeThickness" Value="1.2" />
            <Setter Property="StrokeDashArray" Value="5 8" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="Opacity" Value="0.42" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top"
                                           Margin="0,0,0,12"
                                           FontSize="14"
                                           FontFamily="Bahnschrift SemiCondensed"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PanelLabelBrush}"
                                           Text="{TemplateBinding Header}" />
                                <ContentPresenter />
                            </DockPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentDeepBrush}" />
            <Setter Property="Foreground" Value="#FF111111" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="40" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFFFC56D" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFF59E0B" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFB7B0A8" />
                    <Setter Property="BorderBrush" Value="#FF9CA3AF" />
                    <Setter Property="Foreground" Value="#FF4B5563" />
                    <Setter Property="Opacity" Value="0.72" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#D8FFF7ED" />
            <Setter Property="BorderBrush" Value="#FFD7B18E" />
            <Setter Property="Foreground" Value="#FF7C3315" />
        </Style>

        <Style x:Key="FooterButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Background" Value="#CC0B1220" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PanelTextBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="#FFF4F1EA" />
            <Setter Property="Foreground" Value="#FF111111" />
            <Setter Property="CaretBrush" Value="#FF111111" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="#FFD7B18E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="#FFF4F1EA" />
            <Setter Property="Foreground" Value="#FF111111" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="#FFF4F1EA" />
            <Setter Property="Foreground" Value="#FF111111" />
        </Style>

        <Style x:Key="ReadableComboBoxStyle" TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="#FFD7B18E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="#F4F1EA" />
            <Setter Property="Foreground" Value="#FF111111" />
        </Style>

        <Style x:Key="ReadableComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="#FFF4F1EA" />
            <Setter Property="Foreground" Value="#FF111111" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FFE2C7AC" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFFFE7C2" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                    <Setter Property="Foreground" Value="#FF4B5563" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PanelTextBrush}" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="TabStripPlacement" Value="Left" />
        </Style>

        <Style x:Key="ContentOnlyTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter x:Name="PART_SelectedContentHost"
                                          ContentSource="SelectedContent"
                                          KeyboardNavigation.TabNavigation="Local"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="#CC0A101A" />
            <Setter Property="BorderBrush" Value="#6657C7E8" />
            <Setter Property="Foreground" Value="#FFD7DEE8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinHeight" Value="52" />
        </Style>

        <Style x:Key="ActionTileButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="220" />
            <Setter Property="Height" Value="82" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#FFFFE7C2" />
            <Setter Property="BorderBrush" Value="#FFFFB86B" />
            <Setter Property="Foreground" Value="#FF111111" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#FFD7DEE8" />
            <Setter Property="Background" Value="#B80A101A" />
            <Setter Property="BorderBrush" Value="#6657C7E8" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Margin" Value="0,0,16,12" />
            <Setter Property="Width" Value="232" />
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter Margin="10,0,0,0"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                  RecognizesAccessKey="True"
                                                  ContentSource="Header" />
                                <Border x:Name="ActiveLine"
                                        Width="4"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#F01A2433" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#FFFFB86B" />
                                <Setter TargetName="ActiveLine" Property="Background" Value="#FFFFB86B" />
                                <Setter Property="Foreground" Value="#FFFFE7C2" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#AA67E8F9" />
                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#F4F1EA" />
            <Setter Property="Foreground" Value="#FF111111" />
            <Setter Property="BorderBrush" Value="#FFD7B18E" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="RowBackground" Value="#FFFDFBF7" />
            <Setter Property="AlternatingRowBackground" Value="#FFFFF7ED" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#FF111111" />
            <Setter Property="Background" Value="#FFFDFBF7" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="INSTALLED">
                    <Setter Property="Background" Value="#FFE8FAEF" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="MISSING_REQUIRED">
                    <Setter Property="Background" Value="#FFFFE4E6" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="HASH_FAILED">
                    <Setter Property="Background" Value="#FFFFCDD2" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="MANUAL_REQUIRED">
                    <Setter Property="Background" Value="#FFEFF6FF" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="PLACEHOLDER">
                    <Setter Property="Background" Value="#FFEFF6FF" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="UPDATE_AVAILABLE">
                    <Setter Property="Background" Value="#FFFFF7ED" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFFFE7C2" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="UsbTargetComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="IsEnabled" Value="{Binding IsSelectable}" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="#FFF4F1EA" />
            <Setter Property="Foreground" Value="#FF111111" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FFE2C7AC" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFFFE7C2" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                    <Setter Property="Foreground" Value="#FF4B5563" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#000000"
          ClipToBounds="True"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Image x:Name="CommandCenterBackgroundImage"
               Panel.ZIndex="1"
               Source="Assets/ForgerEMS_CommandCenterBackground.png"
               Stretch="Uniform"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               Opacity="0.9"
               IsHitTestVisible="False"
               RenderOptions.BitmapScalingMode="LowQuality"
               CacheMode="BitmapCache" />

        <Canvas x:Name="TraceLightCanvas"
                Panel.ZIndex="2"
                ClipToBounds="True"
                IsHitTestVisible="False" />

        <Rectangle Panel.ZIndex="3" Opacity="0.2" IsHitTestVisible="False">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile"
                              Viewport="0,0,48,48"
                              ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <DrawingGroup>
                            <GeometryDrawing Brush="Transparent">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,0,48,48" />
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                            <GeometryDrawing>
                                <GeometryDrawing.Pen>
                                    <Pen Brush="#33546D89" Thickness="1" />
                                </GeometryDrawing.Pen>
                                <GeometryDrawing.Geometry>
                                    <GeometryGroup>
                                        <LineGeometry StartPoint="0,0" EndPoint="48,0" />
                                        <LineGeometry StartPoint="0,0" EndPoint="0,48" />
                                    </GeometryGroup>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                            <GeometryDrawing>
                                <GeometryDrawing.Pen>
                                    <Pen Brush="#1C89A7C2" Thickness="1" />
                                </GeometryDrawing.Pen>
                                <GeometryDrawing.Geometry>
                                    <GeometryGroup>
                                        <LineGeometry StartPoint="24,0" EndPoint="24,48" />
                                        <LineGeometry StartPoint="0,24" EndPoint="48,24" />
                                    </GeometryGroup>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingGroup>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Viewbox x:Name="CircuitBackgroundLayer"
                 Panel.ZIndex="4"
                 Margin="-18"
                 Stretch="Fill"
                 Opacity="0.3"
                 IsHitTestVisible="False"
                 CacheMode="BitmapCache">
            <Canvas Width="1180" Height="720">
                <Path Data="M292,172 C380,176 474,214 540,272 M345,545 C435,492 498,402 552,305 M236,224 L310,224 M392,522 L448,522"
                      Stroke="#B038BDF8"
                      Style="{StaticResource CircuitBaseTraceStyle}" />
                <Path x:Name="OsToVentoyPulse"
                      Data="M292,172 C380,176 474,214 540,272 M345,545 C435,492 498,402 552,305"
                      Stroke="#FF38BDF8"
                      Style="{StaticResource CircuitPulseTraceStyle}" />

                <Path Data="M848,520 C770,470 690,386 628,306 M788,568 L858,568 M800,602 L908,602"
                      Stroke="#B0F59E0B"
                      Style="{StaticResource CircuitBaseTraceStyle}" />
                <Path x:Name="RecoveryToVentoyPulse"
                      Data="M848,520 C770,470 690,386 628,306"
                      Stroke="#FFF59E0B"
                      Style="{StaticResource CircuitPulseTraceStyle}" />

                <Path Data="M205,486 C308,448 445,367 548,300 M125,540 L232,540"
                      Stroke="#A622C55E"
                      Style="{StaticResource CircuitBaseTraceStyle}" />
                <Path x:Name="DiagnosticsToVentoyPulse"
                      Data="M205,486 C308,448 445,367 548,300"
                      Stroke="#FF22C55E"
                      Style="{StaticResource CircuitPulseTraceStyle}" />

                <Path Data="M982,325 C870,318 728,309 635,292 M946,366 L1042,366 M940,404 L1088,404"
                      Stroke="#A6A855F7"
                      Style="{StaticResource CircuitBaseTraceStyle}" />
                <Path x:Name="WindowsToolsToVentoyPulse"
                      Data="M982,325 C870,318 728,309 635,292"
                      Stroke="#FFA855F7"
                      Style="{StaticResource CircuitPulseTraceStyle}" />

                <Path Data="M894,172 C800,178 705,220 632,274"
                      Stroke="#A6A855F7"
                      Style="{StaticResource CircuitBaseTraceStyle}" />
                <Path x:Name="MedicatToVentoyPulse"
                      Data="M894,172 C800,178 705,220 632,274"
                      Stroke="#FFA855F7"
                      Style="{StaticResource CircuitPulseTraceStyle}" />

                <Path Data="M590,302 C590,335 590,370 590,404"
                      Stroke="#B8E0F2FE"
                      Style="{StaticResource CircuitBaseTraceStyle}" />
                <Path x:Name="VentoyToUsbPulse"
                      Data="M590,302 C590,335 590,370 590,404"
                      Stroke="#FFE0F2FE"
                      Style="{StaticResource CircuitPulseTraceStyle}" />

                <Path Data="M500,222 C535,230 562,246 590,271 M680,222 C645,230 618,246 590,271"
                      Stroke="#90E0F2FE"
                      Style="{StaticResource CircuitBaseTraceStyle}" />
                <Path x:Name="UsbBuildersToVentoyPulse"
                      Data="M500,222 C535,230 562,246 590,271 M680,222 C645,230 618,246 590,271"
                      Stroke="#FFE0F2FE"
                      Style="{StaticResource CircuitPulseTraceStyle}" />

                <Path Data="M552,288 L628,288 M590,302 L590,404 M292,172 L250,172 M345,545 L296,545 M848,520 L896,520 M894,172 L948,172"
                      Stroke="#78E0F2FE"
                      StrokeThickness="2"
                      StrokeDashArray="10 12"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Opacity="0.24" />

                <Ellipse x:Name="TargetPulseRing"
                         Canvas.Left="514"
                         Canvas.Top="348"
                         Width="152"
                         Height="152"
                         Stroke="#CFE0F2FE"
                         StrokeThickness="2"
                         Opacity="0.08"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="TargetPulseRingScale" ScaleX="0.86" ScaleY="0.86" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Grid Canvas.Left="526"
                      Canvas.Top="358"
                      Width="128"
                      Height="132"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="TargetUsbScale" />
                    </Grid.RenderTransform>
                    <Ellipse x:Name="TargetUsbGlow"
                             Width="128"
                             Height="128"
                             Fill="#4438BDF8"
                             Opacity="0.3" />
                    <Border Width="62"
                            Height="88"
                            Margin="0,3,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Background="#D90B1220"
                            BorderBrush="#FFE0F2FE"
                            BorderThickness="2"
                            CornerRadius="10"
                            Visibility="Collapsed">
                        <Grid>
                            <Rectangle Width="28"
                                       Height="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"
                                       Margin="0,-11,0,0"
                                       RadiusX="3"
                                       RadiusY="3"
                                       Fill="#FFDCEBFF" />
                            <Path Data="M31,12 L48,21 L45,54 C43,66 37,75 31,80 C25,75 19,66 17,54 L14,21 Z"
                                  Fill="#1E38BDF8"
                                  Stroke="#FF38BDF8"
                                  StrokeThickness="1.5"
                                  Stretch="Fill"
                                  Margin="12,15,12,22" />
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,4,0,0"
                                       FontFamily="Bahnschrift SemiCondensed"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#FFE0F2FE"
                                       Text="FE" />
                        </Grid>
                    </Border>
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               FontFamily="Bahnschrift SemiCondensed"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#FFE0F2FE"
                               Opacity="1"
                               Text="TARGET USB"
                               Visibility="Collapsed" />
                </Grid>

                <Canvas x:Name="OsPackageGroup"
                        Canvas.Left="205"
                        Canvas.Top="104"
                        Width="250"
                        Height="500"
                        Background="Transparent"
                        Opacity="0.72"
                        MouseEnter="OnPackageGroupMouseEnter"
                        MouseLeave="OnPackageGroupMouseLeave">
                    <Ellipse x:Name="OsGroupHalo"
                             Tag="Halo"
                             Canvas.Left="0"
                             Canvas.Top="0"
                             Width="250"
                             Height="500"
                             Stroke="#00F59E0B"
                             StrokeThickness="2"
                             Opacity="0" />
                    <TextBlock Tag="CategoryLabel" Canvas.Left="8" Canvas.Top="0" Text="OS IMAGES" Style="{StaticResource PackageGroupLabelStyle}" />
                    <Border Tag="CategoryNode"
                            Canvas.Left="58"
                            Canvas.Top="222"
                            MinWidth="100"
                            Height="30"
                            Padding="12,4"
                            Background="#5A162C42"
                            BorderBrush="#B338BDF8"
