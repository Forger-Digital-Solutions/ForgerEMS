                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding UsbTargets}"
                                          SelectedItem="{Binding SelectedUsbTarget}"
                                          IsEnabled="{Binding IsIdle}"
                                          Background="#F4F1EA"
                                          Foreground="#FF111111"
                                          ItemContainerStyle="{StaticResource UsbTargetComboItemStyle}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="#FF111111"
                                                           Text="{Binding DisplayName}" />
                                                <TextBlock Margin="0,2,0,0"
                                                           FontSize="11.5"
                                                           Foreground="#FF4B5563"
                                                           Text="{Binding SelectionWarningDisplay}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <Button Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Padding="12,8"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Refresh"
                                        Command="{Binding RefreshUsbTargetsCommand}" />
                            </Grid>

                            <TextBlock Margin="0,4,0,8"
                                       FontSize="12"
                                       FontFamily="Bahnschrift SemiCondensed"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PanelLabelBrush}"
                                       Text="Drive Details" />

                            <Grid Margin="0,0,0,12" Grid.IsSharedSizeScope="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="TargetLabel" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Margin="0,0,14,8" FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Drive" />
