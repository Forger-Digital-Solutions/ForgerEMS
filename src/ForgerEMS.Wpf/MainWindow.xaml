                                <TextBlock Grid.Row="1" Margin="0,0,14,8" FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Label" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SelectedUsbTarget.LabelDisplay, TargetNullValue=—}" />

                                <TextBlock Grid.Row="2" Margin="0,0,14,8" FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Capacity" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SelectedUsbTarget.DisplayTotalBytes, TargetNullValue=—}" />

                                <TextBlock Grid.Row="3" Margin="0,0,14,8" FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Free space" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SelectedUsbTarget.DisplayFreeBytes, TargetNullValue=—}" />

                                <TextBlock Grid.Row="4" Margin="0,0,14,8" FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="File system" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SelectedUsbTarget.FileSystem, TargetNullValue=—}" />

                                <TextBlock Grid.Row="5" Margin="0,0,14,8" FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Drive type" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SelectedUsbTarget.SelectionStatusText, TargetNullValue=—}" />

                                <TextBlock Grid.Row="6" Margin="0,0,14,8" FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Bus type" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SelectedUsbTarget.BusTypeDisplay, TargetNullValue=—}" />

                                <TextBlock Grid.Row="7" Margin="0,0,14,8" FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Device" />
                                <TextBlock Grid.Row="7" Grid.Column="1" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SelectedUsbTarget.DeviceIdentityDisplay, TargetNullValue=—}" TextWrapping="Wrap" />

                                <TextBlock Grid.Row="8" Margin="0,0,14,8" FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Read speed" />
                                <TextBlock Grid.Row="8" Grid.Column="1" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SelectedUsbTarget.ReadSpeedDisplayNormalized, TargetNullValue=Not benchmarked}" />

                                <TextBlock Grid.Row="9" Margin="0,0,14,0" FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Write speed" />
                                <TextBlock Grid.Row="9" Grid.Column="1" Margin="0,0,0,8" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SelectedUsbTarget.WriteSpeedDisplayNormalized, TargetNullValue=Not benchmarked}" />

                                <TextBlock Grid.Row="10" Margin="0,0,14,8" FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Benchmark" />
                                <TextBlock Grid.Row="10" Grid.Column="1" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SelectedUsbTarget.BenchmarkStatusDisplay, TargetNullValue=Queued}" />

                                <TextBlock Grid.Row="11" Margin="0,0,14,8" FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Test size" />
                                <TextBlock Grid.Row="11" Grid.Column="1" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SelectedUsbTarget.BenchmarkTestSizeDisplay, TargetNullValue=Not tested}" />

                                <TextBlock Grid.Row="12" Margin="0,0,14,0" FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Last tested" />
                                <TextBlock Grid.Row="12" Grid.Column="1" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SelectedUsbTarget.BenchmarkLastTestedDisplay, TargetNullValue=Never}" />
                            </Grid>

                            <Border Padding="12"
                                    Background="{Binding TargetWarningBackground}"
                                    BorderBrush="{Binding TargetWarningBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <TextBlock FontSize="12"
                                           Foreground="{Binding TargetWarningForeground}"
                                           Text="{Binding TargetWarningText}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Ventoy">
                        <StackPanel>
                            <Border Padding="12"
                                    Background="{Binding VentoyStatusBackground}"
                                    BorderBrush="{Binding VentoyStatusBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{Binding VentoyStatusForeground}"
                                               Text="{Binding VentoyStatusText}" />
                                    <TextBlock Margin="0,5,0,0"
                                               FontSize="12"
                                               Foreground="{Binding VentoyStatusForeground}"
                                               Text="{Binding VentoyDetailText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,10,0,12"
                                       FontSize="12"
                                       Foreground="{DynamicResource PanelMutedTextBrush}"
                                       Text="{Binding VentoyPackageText}"
                                       TextWrapping="Wrap" />

                            <Button Content="Prepare / Convert USB to Ventoy"
                                    Command="{Binding InstallOrUpdateVentoyCommand}" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Actions">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,2">
                                <Button Style="{StaticResource ActionTileButtonStyle}" Command="{Binding VerifyCommand}">
                                    <StackPanel>
                                        <TextBlock FontSize="16" FontWeight="Bold" Text="✓ Verify" />
                                        <TextBlock Margin="0,5,0,0" FontSize="11.5" Text="Run backend checks" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ActionTileButtonStyle}" Command="{Binding RevalidateManagedDownloadsCommand}">
                                    <StackPanel>
                                        <TextBlock FontSize="16" FontWeight="Bold" Text="↻ Revalidate" />
                                        <TextBlock Margin="0,5,0,0" FontSize="11.5" Text="Check managed downloads" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ActionTileButtonStyle}" Command="{Binding SetupUsbCommand}">
                                    <StackPanel>
                                        <TextBlock FontSize="16" FontWeight="Bold" Text="▣ Setup USB" />
                                        <TextBlock Margin="0,5,0,0" FontSize="11.5" Text="Create toolkit layout" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ActionTileButtonStyle}" Command="{Binding UpdateUsbCommand}">
                                    <StackPanel>
                                        <TextBlock FontSize="16" FontWeight="Bold" Text="⇩ Update Toolkit" />
                                        <TextBlock Margin="0,5,0,0" FontSize="11.5" Text="Download managed items" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ActionTileButtonStyle}" Command="{Binding RenameUsbCommand}">
                                    <StackPanel>
                                        <TextBlock FontSize="16" FontWeight="Bold" Text="✎ Rename Drive" />
                                        <TextBlock Margin="0,5,0,0" FontSize="11.5" Text="Set technician label" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ActionTileButtonStyle}" Command="{Binding RefreshAllCommand}">
                                    <StackPanel>
                                        <TextBlock FontSize="16" FontWeight="Bold" Text="⟳ Refresh Backend" />
                                        <TextBlock Margin="0,5,0,0" FontSize="11.5" Text="Reload context" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>

                            <Border Margin="0,6,0,10"
                                    Padding="12"
                                    Background="{Binding TargetWarningBackground}"
                                    BorderBrush="{Binding TargetWarningBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <TextBlock FontSize="12"
                                           Foreground="{Binding TargetWarningForeground}"
                                           Text="{Binding ActionWarningText}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <Border Padding="12"
                                    Background="#B80A101A"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PanelLabelBrush}"
                                               Text="Last command" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{DynamicResource PanelTextBrush}"
                                               Text="{Binding LastCommandText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                        </StackPanel>
                    </TabItem>

                    <TabItem Header="◎  System Intelligence">
                        <StackPanel Margin="24,0,24,0" MaxWidth="1040" HorizontalAlignment="Left">
                            <GroupBox Header="System Intelligence">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border DockPanel.Dock="Left"
                                                Grid.Column="0"
                                                Padding="10,4"
                                                Background="{Binding SystemIntelligenceStatusBackground}"
                                                BorderBrush="{Binding SystemIntelligenceStatusBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="999">
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="{Binding SystemIntelligenceStatusForeground}"
                                                       Text="{Binding SystemIntelligenceStatusText}" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Margin="12,0,12,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource PanelMutedTextBrush}"
                                                   Text="{Binding SystemIntelligenceLastScanText}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="2"
                                                Width="142"
                                                Margin="12,0,0,0"
                                                Content="Run System Scan"
                                                Command="{Binding RunSystemScanCommand}" />
                                        <Button Grid.Column="3"
                                                Width="132"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Open Reports"
                                                Command="{Binding OpenSystemReportFolderCommand}" />
                                        <Button Grid.Column="4"
                                                Width="124"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Copy Summary"
                                                Command="{Binding CopySystemSummaryCommand}" />
                                    </Grid>

                                    <TextBlock Margin="0,0,0,12"
                                               Foreground="{DynamicResource PanelTextBrush}"
                                               Text="{Binding SystemIntelligenceSummaryText}"
                                               TextWrapping="Wrap" />

                                    <UniformGrid Columns="2" Margin="0,0,0,10">
                                        <Border Margin="0,0,8,8" Padding="12" Background="#B80A101A" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="System" />
                                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SystemIntelligenceSystemCardText}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="8,0,0,8" Padding="12" Background="#B80A101A" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="CPU / RAM / GPU" />
                                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SystemIntelligenceComputeCardText}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="0,0,8,8" Padding="12" Background="#B80A101A" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Storage Health" />
                                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SystemIntelligenceStorageCardText}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="8,0,0,8" Padding="12" Background="#B80A101A" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Battery" />
                                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SystemIntelligenceBatteryCardText}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="0,0,8,0" Padding="12" Background="#B80A101A" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Network" />
                                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SystemIntelligenceNetworkCardText}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="8,0,0,0" Padding="12" Background="#B80A101A" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Security" />
                                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SystemIntelligenceSecurityCardText}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="0,8,8,0" Padding="12" Background="#B80A101A" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource PanelLabelBrush}" Text="Flip Value" />
                                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource PanelTextBrush}" Text="{Binding SystemIntelligenceFlipValueCardText}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <TextBlock Margin="0,2,0,8"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PanelLabelBrush}"
                                               Text="Recommendations" />
                                    <ItemsControl ItemsSource="{Binding SystemIntelligenceRecommendations}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,0,6"
                                                           Foreground="{DynamicResource PanelTextBrush}"
                                                           Text="{Binding}"
                                                           TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Margin="0,10,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource PanelMutedTextBrush}"
                                               Text="{Binding SystemIntelligenceReportPathText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="▤  Toolkit Manager">
                        <StackPanel Margin="24,0,24,0" MaxWidth="1040" HorizontalAlignment="Left">
                            <GroupBox Header="Toolkit Manager">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Padding="12,5"
                                                Background="{Binding ToolkitStatusBackground}"
                                                BorderBrush="{Binding ToolkitStatusBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="999">
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="{Binding ToolkitStatusForeground}"
                                                       Text="{Binding ToolkitStatusText}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,12,0">
                                            <TextBlock Foreground="{DynamicResource PanelTextBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding ToolkitHealthVerdictText}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Margin="0,3,0,0"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource PanelMutedTextBrush}"
                                                       Text="{Binding ToolkitLastScanText}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="2"
                                                  Width="320"
                                                  ItemsSource="{Binding UsbTargets}"
                                                  SelectedItem="{Binding SelectedUsbTarget}"
                                                  IsEnabled="{Binding IsIdle}"
                                                  Background="#F4F1EA"
                                                  Foreground="#FF111111"
                                                  ItemContainerStyle="{StaticResource UsbTargetComboItemStyle}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Foreground="#FF111111"
                                                                   Text="{Binding DisplayName}" />
                                                        <TextBlock Margin="0,2,0,0"
                                                                   FontSize="11.5"
                                                                   Foreground="#FF4B5563"
                                                                   Text="{Binding SelectionWarningDisplay}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Grid>

                                    <WrapPanel Margin="0,0,0,12">
                                        <Button Style="{StaticResource ActionTileButtonStyle}"
                                                Command="{Binding RefreshToolkitHealthCommand}">
                                            <StackPanel>
                                                <TextBlock FontSize="15" FontWeight="Bold" Text="↻ Refresh Health" />
                                                <TextBlock Margin="0,5,0,0" FontSize="11.5" Text="Rescan selected target" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource ActionTileButtonStyle}"
                                                Command="{Binding UpdateToolkitCommand}">
                                            <StackPanel>
                                                <TextBlock FontSize="15" FontWeight="Bold" Text="⇩ Update Toolkit" />
                                                <TextBlock Margin="0,5,0,0" FontSize="11.5" Text="Download managed tools" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource ActionTileButtonStyle}"
                                                Command="{Binding OpenToolkitUsbReportsCommand}">
                                            <StackPanel>
                                                <TextBlock FontSize="15" FontWeight="Bold" Text="▣ USB Reports" />
                                                <TextBlock Margin="0,5,0,0" FontSize="11.5" Text="Open target reports" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource ActionTileButtonStyle}"
                                                Command="{Binding OpenToolkitLocalReportsCommand}">
                                            <StackPanel>
                                                <TextBlock FontSize="15" FontWeight="Bold" Text="⌂ Local Reports" />
                                                <TextBlock Margin="0,5,0,0" FontSize="11.5" Text="Open runtime reports" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource ActionTileButtonStyle}"
                                                Command="{Binding RecheckSelectedToolCommand}">
                                            <StackPanel>
                                                <TextBlock FontSize="15" FontWeight="Bold" Text="◎ Recheck Tool" />
                                                <TextBlock Margin="0,5,0,0" FontSize="11.5" Text="Refresh selected detail" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource ActionTileButtonStyle}"
                                                Command="{Binding OpenSelectedToolLocationCommand}">
                                            <StackPanel>
                                                <TextBlock FontSize="15" FontWeight="Bold" Text="⌕ Open Location" />
                                                <TextBlock Margin="0,5,0,0" FontSize="11.5" Text="Show found folder" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource ActionTileButtonStyle}"
                                                Command="{Binding OpenManualDownloadShortcutCommand}">
                                            <StackPanel>
                                                <TextBlock FontSize="15" FontWeight="Bold" Text="↗ Manual Link" />
                                                <TextBlock Margin="0,5,0,0" FontSize="11.5" Text="Open shortcut or URL" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>

                                    <TextBlock Margin="0,0,0,12"
                                               FontSize="12"
                                               Foreground="{DynamicResource PanelMutedTextBrush}"
                                               Text="{Binding ToolkitManualExplanationText}"
                                               TextWrapping="Wrap" />

                                    <WrapPanel Margin="0,0,0,12">
                                        <Border MinWidth="145" Margin="0,0,8,8" Padding="10,5" Background="#E8F7F3EA" BorderBrush="#FFD7B18E" BorderThickness="1" CornerRadius="9">
                                            <TextBlock Foreground="#FF111111" FontWeight="SemiBold" Text="{Binding ToolkitInstalledCountText}" />
                                        </Border>
                                        <Border MinWidth="175" Margin="0,0,8,8" Padding="10,5" Background="#FFFFF7ED" BorderBrush="#FFF59E0B" BorderThickness="1" CornerRadius="9">
                                            <TextBlock Foreground="#FF92400E" FontWeight="SemiBold" Text="{Binding ToolkitMissingCountText}" />
                                        </Border>
                                        <Border MinWidth="130" Margin="0,0,8,8" Padding="10,5" Background="#FFFFF7ED" BorderBrush="#FFF59E0B" BorderThickness="1" CornerRadius="9">
                                            <TextBlock Foreground="#FF92400E" FontWeight="SemiBold" Text="{Binding ToolkitUpdatesCountText}" />
                                        </Border>
                                        <Border MinWidth="120" Margin="0,0,8,8" Padding="10,5" Background="#FFFFF1F2" BorderBrush="#FFF87171" BorderThickness="1" CornerRadius="9">
                                            <TextBlock Foreground="#FF991B1B" FontWeight="SemiBold" Text="{Binding ToolkitFailedCountText}" />
                                        </Border>
                                        <Border MinWidth="120" Margin="0,0,8,8" Padding="10,5" Background="#FFFFF7ED" BorderBrush="#FFD7B18E" BorderThickness="1" CornerRadius="9">
                                            <TextBlock Foreground="#FF7C3315" FontWeight="SemiBold" Text="{Binding ToolkitManualCountText}" />
                                        </Border>
                                        <Border MinWidth="190" Margin="0,0,8,8" Padding="10,5" Background="#FFEFF6FF" BorderBrush="#FF67B7E8" BorderThickness="1" CornerRadius="9">
                                            <TextBlock Foreground="#FF174E75" FontWeight="SemiBold" Text="{Binding ToolkitPlaceholderCountText}" />
                                        </Border>
                                    </WrapPanel>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Margin="0,0,12,0"
                                                 Text="{Binding ToolkitSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Search toolkit inventory" />
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PanelLabelBrush}"
                                                   Text="Status" />
                                        <ComboBox Grid.Column="2"
                                                  Margin="0,0,12,0"
                                                  ItemsSource="{Binding ToolkitFilterOptions}"
                                                  SelectedItem="{Binding SelectedToolkitFilter}"
                                                  Style="{StaticResource ReadableComboBoxStyle}"
                                                  ItemContainerStyle="{StaticResource ReadableComboBoxItemStyle}" />
                                        <TextBlock Grid.Column="3"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PanelLabelBrush}"
                                                   Text="Category" />
                                        <ComboBox Grid.Column="4"
                                                  ItemsSource="{Binding ToolkitCategoryFilterOptions}"
                                                  SelectedItem="{Binding SelectedToolkitCategoryFilter}"
                                                  Style="{StaticResource ReadableComboBoxStyle}"
                                                  ItemContainerStyle="{StaticResource ReadableComboBoxItemStyle}" />
                                    </Grid>

                                    <ScrollViewer Height="430"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Disabled">
                                        <DataGrid MinWidth="1220"
                                                  AutoGenerateColumns="False"
                                                  ItemsSource="{Binding ToolkitHealthItems}"
                                                  SelectedItem="{Binding SelectedToolkitHealthItem, Mode=TwoWay}"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Tool" Binding="{Binding Tool}" Width="180" />
                                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" />
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" />
                                                <DataGridTextColumn Header="Managed/Manual" Binding="{Binding Type}" Width="140" />
                                                <DataGridTextColumn Header="Expected Path" Binding="{Binding ExpectedFoundPath}" Width="280" />
                                                <DataGridTextColumn Header="Verification" Binding="{Binding Verification}" Width="170" />
                                                <DataGridTextColumn Header="Recommendation" Binding="{Binding Recommendation}" Width="280" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </ScrollViewer>

                                    <Border Margin="0,12,0,0"
                                            Padding="12"
                                            Background="#B80A101A"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PanelLabelBrush}"
                                                       Text="Selected Tool Recommendation" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{DynamicResource PanelTextBrush}"
                                                       Text="{Binding SelectedToolkitDetailText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Margin="0,10,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource PanelMutedTextBrush}"
                                               Text="{Binding ToolkitReportPathText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="◇  ForgerEMS Copilot">
                        <StackPanel Margin="24,0,24,0" MaxWidth="1040" HorizontalAlignment="Left">
                            <GroupBox Header="ForgerEMS Copilot">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="360" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Margin="0,0,0,12"
                                            Padding="12"
                                            Background="#B80A101A"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="220" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Margin="0,0,10,0"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PanelLabelBrush}"
                                                       Text="Mode" />
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding CopilotModeOptions}"
                                                      SelectedItem="{Binding SelectedCopilotMode}"
                                                      Style="{StaticResource ReadableComboBoxStyle}"
                                                      ItemContainerStyle="{StaticResource ReadableComboBoxItemStyle}" />
                                            <Border Grid.Column="2"
                                                    Margin="12,0,0,0"
                                                    Padding="10,4"
                                                    Background="{Binding CopilotOnlineStatusBackground}"
                                                    BorderBrush="{Binding CopilotOnlineStatusBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="999">
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="{Binding CopilotOnlineStatusForeground}"
                                                           Text="{Binding CopilotOnlineStatusText}"
                                                           TextWrapping="Wrap" />
                                            </Border>
                                            <Button Grid.Column="3"
                                                    Width="150"
                                                    Margin="12,0,0,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="Clear History"
                                                    Command="{Binding ClearCopilotHistoryCommand}" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Margin="0,0,0,12"
                                            Padding="12"
                                            Background="#B80A101A"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PanelLabelBrush}"
                                                       Text="Local Context" />
                                            <TextBlock Margin="0,6,0,0"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource PanelTextBrush}"
                                                       Text="{Binding CopilotContextText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Margin="0,0,0,12"
                                            Padding="12"
                                            Background="#B80A101A"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Margin="0,0,0,8"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PanelLabelBrush}"
                                                       Text="Provider Hooks" />
                                            <ItemsControl ItemsSource="{Binding CopilotProviderSettings}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Margin="0,0,0,6"
                                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                            <StackPanel>
                                                                <TextBlock FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource PanelTextBrush}"
                                                                           Text="{Binding DisplayName}" />
                                                                <TextBlock Margin="0,2,0,0"
                                                                           FontSize="11.5"
                                                                           Foreground="{DynamicResource PanelMutedTextBrush}"
                                                                           Text="{Binding DetailText}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </CheckBox>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <WrapPanel Grid.Row="3" Margin="0,0,0,12">
                                        <Button MinWidth="166" Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Content="What is this laptop worth?" Command="{Binding AskCopilotValueCommand}" />
                                        <Button MinWidth="206" Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Content="What should I upgrade before selling?" Command="{Binding AskCopilotUpgradeCommand}" />
                                        <Button MinWidth="174" Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Content="Why is my computer lagging?" Command="{Binding AskCopilotLagCommand}" />
                                        <Button MinWidth="164" Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Content="Best OS for this machine?" Command="{Binding AskCopilotOsCommand}" />
                                        <Button MinWidth="184" Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Content="Best USB toolkit for this job?" Command="{Binding AskCopilotUsbCommand}" />
                                        <Button MinWidth="168" Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Content="What does this warning mean?" Command="{Binding AskCopilotWarningCommand}" />
                                    </WrapPanel>

                                    <Border Grid.Row="4"
                                            Padding="12"
                                            Background="#CC050911"
                                            BorderBrush="#4457C7E8"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding CopilotMessages}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,10"
                                                                Padding="10"
                                                                Background="#B80A101A"
                                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="8">
                                                            <StackPanel>
                                                                <TextBlock FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource PanelLabelBrush}"
                                                                           Text="{Binding Role}" />
                                                                <TextBlock Margin="0,5,0,0"
                                                                           Foreground="{DynamicResource PanelTextBrush}"
                                                                           Text="{Binding Text}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>

                                    <Grid Grid.Row="5" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 MinHeight="42"
                                                 Text="{Binding CopilotInput, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True" />
                                        <Button Grid.Column="1"
                                                Width="110"
                                                Margin="10,0,0,0"
                                                Content="Send"
                                                Command="{Binding SendCopilotMessageCommand}" />
                                    </Grid>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="⚙  Diagnostics">
                        <StackPanel Margin="24,0,24,0" MaxWidth="1040" HorizontalAlignment="Left">
                            <GroupBox Header="App Diagnostics">
                                <StackPanel>
                                    <Border Margin="0,0,0,14"
                                            Padding="12"
                                            Background="#FF0A101A"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PanelLabelBrush}"
                                                       Text="Backend status" />
                                            <TextBlock Margin="0,6,0,0"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource PanelTextBrush}"
                                                       Text="{Binding BackendVersionText}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource PanelMutedTextBrush}"
                                                       Text="{Binding BackendRootText}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource PanelMutedTextBrush}"
                                                       Text="{Binding BackendDiagnosticText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <WrapPanel Margin="0,0,0,12">
                                        <Button MinWidth="170"
                                                Margin="0,0,8,8"
                                                Content="Refresh Backend Context"
                                                Command="{Binding RefreshAllCommand}" />
                                        <Button MinWidth="150"
                                                Margin="0,0,8,8"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Check WSL installed"
                                                Command="{Binding CheckWslInstalledCommand}" />
                                        <Button MinWidth="140"
                                                Margin="0,0,8,8"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Show WSL distros"
                                                Command="{Binding ShowWslDistrosCommand}" />
                                        <Button MinWidth="190"
                                                Margin="0,0,8,8"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Open Ubuntu / WSL Terminal"
                                                Command="{Binding OpenUbuntuTerminalCommand}" />
                                    </WrapPanel>

                                    <Border Padding="12"
                                            Background="#FF0A101A"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PanelLabelBrush}"
                                                       Text="Last command" />
                                            <TextBlock Margin="0,6,0,0"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource PanelTextBrush}"
                                                       Text="{Binding LastCommandText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="☰  Settings">
                        <StackPanel Margin="24,0,24,0" MaxWidth="1040" HorizontalAlignment="Left">
                            <GroupBox Header="Settings">
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,10"
                                               FontSize="12"
                                               Foreground="{DynamicResource PanelMutedTextBrush}"
                                               Text="Visuals"
                                               TextWrapping="Wrap" />

                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Margin="0,0,14,10"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PanelLabelBrush}"
                                                   Text="Animated Background" />
                                        <CheckBox x:Name="AnimatedBackgroundCheckBox"
                                                  Grid.Row="0"
                                                  Grid.Column="1"
                                                  Margin="0,0,0,10"
                                                  VerticalAlignment="Center"
                                                  Content="On"
                                                  Checked="OnAnimatedBackgroundSettingChanged"
                                                  Unchecked="OnAnimatedBackgroundSettingChanged" />

                                        <TextBlock Grid.Row="1"
                                                   Margin="0,0,14,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PanelLabelBrush}"
                                                   Text="Background Detail" />
                                        <ComboBox x:Name="BackgroundDetailComboBox"
                                                  Grid.Row="1"
                                                  Grid.Column="1"
                                                  Width="132"
                                                  MinHeight="30"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ReadableComboBoxStyle}"
                                                  ItemContainerStyle="{StaticResource ReadableComboBoxItemStyle}"
                                                  SelectionChanged="OnBackgroundDetailSelectionChanged">
                                            <ComboBoxItem Content="Low" />
                                            <ComboBoxItem Content="Medium" />
                                            <ComboBoxItem Content="High" />
                                        </ComboBox>
                                    </Grid>

                                    <WrapPanel>
                                        <Button MinWidth="90"
                                                Margin="0,0,8,8"
                                                Style="{StaticResource FooterButtonStyle}"
                                                Content="About"
                                                Command="{Binding ShowAboutCommand}" />
                                        <Button MinWidth="90"
                                                Margin="0,0,8,8"
                                                Style="{StaticResource FooterButtonStyle}"
                                                Content="FAQ"
                                                Command="{Binding ShowFaqCommand}" />
                                        <Button MinWidth="90"
                                                Margin="0,0,8,8"
                                                Style="{StaticResource FooterButtonStyle}"
                                                Content="Legal"
                                                Command="{Binding ShowLegalCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </ScrollViewer>

        </Grid>

        </Grid>

        <Grid x:Name="FullLogsOverlay"
              Panel.ZIndex="40"
              Visibility="Collapsed"
              Background="#B8000000">
            <Border Width="920"
                    MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                    Height="620"
                    MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                    Padding="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#F0080D14"
                    BorderBrush="#AA67B7E8"
                    BorderThickness="1"
                    CornerRadius="12">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="Bahnschrift SemiCondensed"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#FFFFDAB8"
                                   Text="Full Logs" />
                        <ComboBox Grid.Column="1"
                                  Width="128"
                                  Margin="12,0,0,0"
                                  ItemsSource="{Binding LogLevelFilterOptions}"
                                  SelectedItem="{Binding SelectedLogLevelFilter}"
                                  Style="{StaticResource ReadableComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource ReadableComboBoxItemStyle}" />
                        <CheckBox Grid.Column="2"
                                  Margin="12,0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding AutoScrollLogs}"
                                  Content="Auto-scroll" />
                        <Button Grid.Column="3"
                                Width="86"
                                Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Copy"
                                Command="{Binding CopyLogsCommand}" />
                        <Button Grid.Column="4"
                                Width="86"
                                Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Clear"
                                Command="{Binding ClearLogsCommand}" />
                        <Button Grid.Column="5"
                                Width="86"
                                Margin="0"
                                Style="{StaticResource FooterButtonStyle}"
                                Content="Close"
                                Click="OnCloseFullLogsClick" />
                    </Grid>

                    <TextBox x:Name="LogTextBox"
                             Background="#E6050911"
                             BorderBrush="#8867B7E8"
                             BorderThickness="1"
                             Padding="16"
                             FontFamily="Consolas"
                             FontSize="12.5"
                             Foreground="#FFE0E8F4"
                             SelectionBrush="#FFD7B18E"
                             IsReadOnly="True"
                             IsUndoEnabled="False"
                             Text="{Binding LogsText, Mode=OneWay}"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

