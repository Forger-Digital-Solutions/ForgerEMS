# Copy to .env for local tooling only — the WPF app reads Windows environment variables, not this file.
# See docs/ENVIRONMENT.md for semantics.

FORGEREMS_ENV=Development
FORGEREMS_RELEASE_CHANNEL=preview
FORGEREMS_TELEMETRY_ENABLED=false
FORGEREMS_CRASH_REPORTING_ENABLED=false

FORGEREMS_GITHUB_OWNER=Forger-Digital-Solutions
FORGEREMS_GITHUB_REPO=ForgerEMS
FORGEREMS_UPDATE_USER_AGENT=ForgerEMS
FORGEREMS_UPDATE_TIMEOUT_SECONDS=20

FORGEREMS_KYRA_MODE=hybrid
FORGEREMS_KYRA_ONLINE_ENABLED=false
# FORGEREMS_OPENAI_API_KEY=
# FORGEREMS_OPENAI_BASE_URL=
# FORGEREMS_OPENAI_MODEL=

FORGEREMS_LICENSE_TIER=PublicPreview
